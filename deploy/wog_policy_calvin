def _parse_epoch_from_name(path: Path) -> int | None:
    m = re.search(r"epoch-(\d+)", path.stem)
    return int(m.group(1)) if m else None


def _select_checkpoints(checkpoints_dir: str, start_epoch: int, max_count: int) -> list[Path]:
    ckpt_dir = Path(checkpoints_dir)
    candidates = [p for p in ckpt_dir.glob("*.pt")]
    items = []
    for p in candidates:
        e = _parse_epoch_from_name(p)
        if e is not None and e >= start_epoch:
            items.append((e, p))
    items.sort(key=lambda x: x[0])
    selected = [p for _, p in (items[-max_count:] if len(items) > max_count else items)]
    return selected


def _spawn_multi_runs(script_path: Path, dataset_path: str, eval_log_dir: str, checkpoints: list[Path], devices: list[int], extra_args: list[str]):
    procs = []
    for ckpt, dev in zip(checkpoints, devices):
        env = os.environ.copy()
        env["CUDA_VISIBLE_DEVICES"] = str(dev)
        env["PYOPENGL_PLATFORM"] = env.get("PYOPENGL_PLATFORM", "egl")
        cmd = [sys.executable, script_path.as_posix(), "--checkpoint", ckpt.as_posix(), "--dataset_path", dataset_path, "--eval_log_dir", eval_log_dir] + extra_args
        logger.info(f"[GPU {dev}] Launching: {' '.join(cmd)}")
        procs.append(subprocess.Popen(cmd, env=env))
    for p in procs:
        p.wait()

def get_epoch(checkpoint):
    if "=" not in checkpoint.stem:
        return "0"
    checkpoint.stem.split("=")[1]


